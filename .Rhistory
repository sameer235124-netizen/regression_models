heart <- read.csv("heartattack.csv")
heart <- read.csv("heart_attack.csv")
head(heart)
summary(heart)
heart$target <- as.factor(heart$target)
set.seed(123)
sample_size <- floor(0.8 * nrow(heart))
train_index <- sample(seq_len(nrow(heart)), size = sample_size)
train_h <- heart[train_index, ]
test_h <- heart[-train_index, ]
model_log <- glm(target ~ ., data = train_h, family = binomial)
summary(model_log)
prob <- predict(model_log, newdata = test_h, type = "response")
pred <- ifelse(prob > 0.5, 1, 0)
pred <- as.factor(pred)
